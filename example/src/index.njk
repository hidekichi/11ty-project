---
layout: base.njk
title: Home
pagination:
  data: collections.posts
  size: 5
  alias: posts
  reverse: true
---

<div class="home-container">

  <section class="home-hero">
    <p class="hero-eyebrow">Journal</p>
    <h1 class="hero-title">{{ site.name }}</h1>
    <p class="hero-description">{{ site.description }}</p>
  </section>

  <section class="post-list-section">
    <div class="post-list">
      {%- for post in collections.posts | reverse -%}
        <article class="post-card">
          <div class="post-card-meta">
            <time datetime="{{ post.date | dateISO }}">{{ post.date | dateJP }}</time>
            {% if post.data.tags %}
              <div class="post-card-tags">
                {% for tag in post.data.tags | excludeTag("posts") %}
                  <span class="post-tag">{{ tag }}</span>
                {% endfor %}
              </div>
            {% endif %}
          </div>
          <h2 class="post-card-title">
            <a href="{{ post.url }}">{{ post.data.title }}</a>
          </h2>
          {% if post.data.description %}
            <p class="post-card-excerpt">{{ post.data.description }}</p>
          {% endif %}
        </article>
      {%- endfor -%}
    </div>
  </section>

</div>
